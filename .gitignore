# Python caches and tool caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
wheels/

# Local environment and secrets
.env
.env.local
.env.shared
.env.test
secrets.json
*.pem
*.key

# Native and build outputs
*.pdb
*.ilk
*.lib
*.dll
*.exp
out/
x64/
Release/
Debug/
build/
dist/

# Local editor and workspace folders
.vscode/
.claude/
.agents/
.tmp/
.devcontainer/
.worktrees/

# Machine-local state and reports
state/plan_state.json
security_report.html
DEV-COMMANDS.md

# Local generated logs and transient reports
logs/*.log
logs/*.ndjson

# Local verification and runtime snapshots that should not churn in git
logs/env_report.json
logs/bundle_install_report.json
logs/diagnostics_export.json
logs/verification/status_snapshot.json

# Keep meaningful checked-in log/report artifacts when intentionally added
!logs/quality-gate.log
!logs/verify-requirements-evidence.md
!logs/native_harness_validation.log
!logs/native_harness_build.log
!logs/lazy-agent-report-rework-plan.log

# Codex local runtime junk only
.codex/sessions/
.codex/tmp/
.codex/*.sqlite
.codex/*.sqlite-shm
.codex/*.sqlite-wal
.codex/logs_*.sqlite
.codex/logs_*.sqlite-shm
.codex/logs_*.sqlite-wal
.codex/state_*.sqlite
.codex/state_*.sqlite-shm
.codex/state_*.sqlite-wal
