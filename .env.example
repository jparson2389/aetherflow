# --- OpenAI Automation ---
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=sk-your-key-here-do-not-commit-real-one
GITHUB_PAT_TOKEN=ghp_your_token_here

# --- gRPC Backend Configuration ---
# The address where the C++ backend is listening
AETHERFLOW_GRPC_HOST=localhost
AETHERFLOW_GRPC_PORT=50051

# --- Logging & Debugging ---
# Options: DEBUG, INFO, WARNING, ERROR (matches your .cursorrules)
LOG_LEVEL=INFO
DEBUG_MODE=False

# --- Hardware/Controller Settings ---
# Specific to your high-performance adapter logic
CONTROLLER_POLLING_RATE_HZ=1000