{
    "printWidth": 88,
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": [
                "*.json",
                "*.jsonc"
            ],
            "options": {
                "trailingComma": "none"
            }
        },
        {
            "files": [
                "*.yaml",
                "*.yml"
            ],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "*.md",
            "options": {
                "printWidth": 1000,
                "tabWidth": 2,
                "proseWrap": "preserve"
            }
        }
    ]
}